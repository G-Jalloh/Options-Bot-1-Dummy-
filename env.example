"""
run.py
──────
Entry point for the Agent Squad trading system.

Usage
─────
  python run.py                   Auto-detect mode from .env
  python run.py --simulate        Force simulation (no credentials)
  python run.py --cycles 10       Run 10 cycles then exit
  python run.py --cycles 0        Run forever (default)
  python run.py --cycle-secs 30   Scan every 30 seconds
  python run.py --db path/to.db   Use a custom flow database

Examples
────────
  python run.py --simulate --cycles 5
      → 5 cycles in simulation mode, then exit

  python run.py --cycles 0
      → Production mode (live if .env has real keys)
      → Press Ctrl+C to stop
"""

import argparse
import asyncio
import sys

from config import AgentConfig
from agent_squad import AgentOrchestrator


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description="Webull Agent Squad — Automated Options Flow Scanner"
    )
    p.add_argument(
        "--simulate", action="store_true",
        help="Force simulation mode (overrides .env credentials)"
    )
    p.add_argument(
        "--cycles", type=int, default=0,
        help="Number of cycles to run. 0 = infinite (default: 0)"
    )
    p.add_argument(
        "--cycle-secs", type=int, default=None,
        help="Seconds between cycles (default: from .env or 60s)"
    )
    p.add_argument(
        "--db", type=str, default=None,
        help="Path to options_flow.db (default: from .env)"
    )
    return p.parse_args()


async def main() -> None:
    args = parse_args()

    cfg = AgentConfig()

    # CLI overrides
    if args.cycle_secs is not None:
        cfg.cycle_seconds = args.cycle_secs
    if args.db is not None:
        cfg.db_path = args.db

    print("\n" + "═" * 55)
    print("  AGENT SQUAD CONFIGURATION")
    print("─" * 55)
    print(cfg.summary())
    print("═" * 55 + "\n")

    orchestrator = AgentOrchestrator(
        db_path       = cfg.db_path,
        cycle_seconds = cfg.cycle_seconds,
        max_cycles    = args.cycles,
        force_sim     = args.simulate or not cfg.is_live,
    )

    try:
        await orchestrator.run()
    except KeyboardInterrupt:
        print("\n\n⛔  Stopped by user. Goodbye.\n")
        sys.exit(0)


if __name__ == "__main__":
    asyncio.run(main())
